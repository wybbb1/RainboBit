<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.wybbb.rainbobit.mapper.RoleMapper" >

    <select id="selectByUserId" parameterType="java.lang.Long" resultType="com.wybbb.rainbobit.pojo.entity.Role">
        SELECT DISTINCT
            r.*
        FROM
            sys_user_role ur
                LEFT JOIN sys_role r ON ur.role_id = r.id
        WHERE
            ur.user_id = #{userId}
          AND r.del_flag = '0'
          AND r.status = '0'
    </select>
</mapper>