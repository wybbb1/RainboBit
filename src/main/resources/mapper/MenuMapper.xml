<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.wybbb.rainbobit.mapper.MenuMapper">

    <!--
        根据用户ID查询其对应的菜单perms。
        该查询通过 sys_user_role -> sys_role_menu -> sys_menu 三张表进行关联，
        并筛选出未删除、状态正常的菜单和按钮的权限标识。
    -->
    <select id="selectByUserId" parameterType="java.lang.Long" resultType="com.wybbb.rainbobit.pojo.entity.Menu">
        SELECT
            m.*
        FROM
            sys_user_role ur
                LEFT JOIN sys_role_menu rm ON ur.role_id = rm.role_id
                LEFT JOIN sys_menu m ON rm.menu_id = m.id
        WHERE
            ur.user_id = #{userId}
          AND m.del_flag = '0'
          AND m.status = '0'
          AND m.menu_type IN ('C', 'F')
    </select>

</mapper>
